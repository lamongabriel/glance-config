# Copy to .env and fill in. Used by compose.dev.yml (and referenced by the
# Coolify env vars in production).

# Shown in the browser tab / PWA name.
GLANCE_APP_NAME=Glance (dev)

# Weather widget location. Add a state for ambiguous US cities, e.g.
# "Greenville, North Carolina, United States".
GLANCE_WEATHER_LOCATION=London, United Kingdom

# GitHub read-only token to raise the releases/repository widget rate limit.
# Create one at https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=
